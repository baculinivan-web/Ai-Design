VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# AI Providers (Cloudflare Pages Secrets - DO NOT USE VITE_ prefix for keys)
# BLOCKRUN_WALLET_KEY=your_blockrun_key
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# PROVIDERS_CONFIG={"openai":{"base_url":"https://api.openai.com","api_key_env":"OPENAI_API_KEY"},"openrouter":{"base_url":"https://openrouter.ai/api/v1","api_key_env":"OPENROUTER_API_KEY"},"custom":{"base_url":"http://46.226.165.141:20128/v1","api_key_env":"CUSTOM_API_KEY"}}
# Note: For Cloudflare Dashboard, DO NOT use outer quotes. For api.openai.com and openrouter.ai, /v1 is automatically appended if missing.
# HTTP endpoints (without HTTPS) are supported - Cloudflare Functions will proxy them securely.

